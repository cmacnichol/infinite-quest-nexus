APP_PORT=8080
LOG_LEVEL=info
POSTGRES_PASSWORD=replace-with-a-long-local-password
DATABASE_URL=postgresql://infinitequest:replace-me@postgres:5432/infinitequest
ASSET_STORAGE_DRIVER=filesystem
ASSET_STORAGE_ROOT=/var/lib/infinitequest/assets
WEB_ROOT=/app/apps/web/public
LEGACY_INDEX_PATH=/app/index.html
WORKER_POLL_INTERVAL_MS=2000
# Required only when saving an API key in a provider profile. Use a long random value.
CREDENTIAL_ENCRYPTION_KEY=
